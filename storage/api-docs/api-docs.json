    "paths": {
        "/api/v1/donors": {
            "get": {
                "tags": [
                    "Donors"
                ],
                "summary": "Get list of all blood donors",
                "description": "Returns a list of donors with optional filtering by blood group.",
                "operationId": "7fa3a663d2963d8009389909f8b0de44",
                "parameters": [
                    {
                        "name": "blood_group",
                        "in": "query",
                        "description": "Filter donors by blood group (e.g., A+, B-, O+)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/DonorResource"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden - Admin access required"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Donors"
                ],
                "summary": "Register a new donor",
                "operationId": "c98958fba82450f50b33ec7b2a69860f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "userId",
                                    "blood_group",
                                    "gender",
                                    "age"
                                ],
                                "properties": {
                                    "userId": {
                                        "type": "integer",
                                        "example": 5
                                    },
                                    "blood_group": {
                                        "type": "string",
                                        "example": "O+"
                                    },
                                    "gender": {
                                        "type": "string",
                                        "example": "male"
                                    },
                                    "age": {
                                        "type": "integer",
                                        "example": 26
                                    },
                                    "lastDonation": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2025-12-01"
                                    },
                                    "isActive": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Donor created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DonorResource"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },

                                "properties": {
                                    "hospitalId": {
                                        "type": "number",
                                        "example": "1"
                                    },
                                    "roleId": {
                                        "type": "number",
                                        "example": "3"
                                    },
                                    "userName": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "johndoe@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "Password123"
                                    },
                                    "isActive": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
